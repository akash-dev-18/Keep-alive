# Frontend gitignore

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js / build outputs
.next/
out/
build/
.turbo/
.vercel/
coverage/
*.tsbuildinfo
next-env.d.ts

# Frontend environment files
.env
.env.*
*.env
*.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
